{
  "name": "prosper-server",
  "private": true,
  "type": "module",
  "description": "Prosper backend — license/auth + settings sync on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply prosper --remote",
    "db:migrate:local": "wrangler d1 migrations apply prosper --local",
    "gen:keys": "node scripts/gen-keys.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.20.0"
  }
}
