<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Prosper</string>
	<key>CFBundleExecutable</key>
	<string>ProsperApp</string>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>eu.illegible.prosper</string>
	<key>CFBundleName</key>
	<string>Prosper</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Placeholder only. The real version is stamped at bundle time from the
	     git tag via PROSPER_VERSION (scripts/bundle.sh). Do not edit by hand. -->
	<key>CFBundleShortVersionString</key>
	<string>0.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<!-- Menu-bar agent: no Dock tile / no Cmd-Tab entry. LSUIElement pins the
	     initial activation policy to .accessory so AppKit never promotes us to
	     .regular (the racy tail-of-launch promotion that left a stray Dock icon
	     when the flag was absent). DockPolicy still flips to .regular at runtime
	     while a Prosper window is open and back to .accessory on close.
	     LSUIElement does NOT exclude the app from the "Default web browser"
	     picker — that list is driven by CFBundleURLTypes (http/https) + the
	     LaunchServices registration below; menu-bar router agents (Velja,
	     Browserosaurus, Finicky) ship LSUIElement and still appear there. -->
	<key>LSUIElement</key>
	<true/>
	<!-- Lets Prosper register as a default web browser so a Lua extension can
	     intercept opened links (host API §O url-dispatcher). Inert until the user
	     sets Prosper default via host.url.set_default_browser; opened URLs arrive as
	     the "url.open" event. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Web URL</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>http</string>
				<string>https</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>Prosper Control</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>prosper</string>
			</array>
		</dict>
	</array>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSAppleEventsUsageDescription</key>
	<string>Prosper sends Apple Events to control other apps for extensions you enable — e.g. routing a clicked link to a chosen browser, or running an osascript automation from your Hammerspoon config.</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUFeedURL</key>
	<string>https://github.com/ventsislav-georgiev/prosper/releases/latest/download/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>FDGYa9u6ip6f93IilJhHfof0DgQnggdXx5Ow/LhbBVs=</string>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
