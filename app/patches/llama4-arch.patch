+//
+//  Llama4.swift
+//  mlx-swift-lm
+//
+//  Faithful port of https://github.com/ml-explore/mlx-lm/blob/main/mlx_lm/models/llama4.py
+//  (text-only — vision tower + multimodal projector are stripped in `sanitize`).
+//
+// ─────────────────────────────────────────────────────────────────────────────
+// VERIFIED CHECKPOINT KEY MAPPING (mlx-community/Llama-4-Scout-17B-16E-Instruct-4bit)
+// ─────────────────────────────────────────────────────────────────────────────
+// Top config.json: model_type "llama4", nested `text_config` (model_type
+// "llama4_text") holds the LM params; quantization {group_size:64, bits:4}.
+// Weight keys are prefixed `language_model.…`, so the module tree below nests a
+// `language_model` submodule (→ `model` + `lm_head`) and the keys map 1:1 with
+// NO renaming except the expert fuse-split done in `sanitize`:
+//
+//   language_model.model.embed_tokens.weight                      → language_model.model.embedTokens
+//   language_model.model.layers.N.self_attn.{q,k,v,o}_proj.weight → …self_attn.{wq,wk,wv,wo}
+//   language_model.model.layers.N.input_layernorm.weight          → …input_layernorm
+//   language_model.model.layers.N.post_attention_layernorm.weight → …post_attention_layernorm
+//   language_model.model.layers.N.feed_forward.router.weight      → …feed_forward.router  (MoE layer)
+//   language_model.model.layers.N.feed_forward.experts.gate_up_proj (FUSED, bare, no `.weight`)
+//   language_model.model.layers.N.feed_forward.experts.down_proj    (FUSED, bare, no `.weight`)
+//   language_model.model.layers.N.feed_forward.shared_expert.{gate,up,down}_proj.weight
+//   language_model.model.norm.weight                              → language_model.model.norm
+//   language_model.lm_head.weight                                 → language_model.lmHead  (tie_word_embeddings=false)
+//   vision_model.* / multi_modal_projector.*                      → REMOVED in sanitize
+//
+// EXPERT-QUANT SPLIT DECISION (the #1 correctness risk in the task):
+//   The model.safetensors.index.json for the 4bit repo contains ZERO `.scales`
+//   and ZERO `.biases` keys for ANY tensor (verified: scales|biases match → 0).
+//   The fused expert tensors are stored at full precision (bf16); this MLX
+//   checkpoint quantizes at LOAD time (ModelFactory reads config.json's
+//   `quantization` block and calls `quantize(model:)` AFTER `sanitize`).
+//   Therefore the experts are NOT packed-int4 here and we replicate the Python
+//   reference's plain float `mx.split(v, 2, axis=-1)` + `swapaxes(1, 2)`
+//   directly. No packed-tensor / `.scales`/`.biases` splitting is needed (that
+//   hazard only applies to repos that pre-quantize the fused expert tensors on
+//   disk, which this one does not).
+// ─────────────────────────────────────────────────────────────────────────────
+
+import Foundation
+import MLX
+import MLXLMCommon
+import MLXNN
+
+// MARK: - Configuration
+
+/// Text-side params (mirrors Python `TextArgs`). Used directly for a `llama4_text`
+/// checkpoint, and as the nested `text_config` of a full `llama4` checkpoint.
+public struct Llama4TextConfiguration: Codable, Sendable {
+    var modelType: String = "llama4_text"
+    var hiddenSize: Int
+    var hiddenLayers: Int
+    var intermediateSize: Int
+    var intermediateSizeMLP: Int
+    var attentionHeads: Int
+    var kvHeads: Int
+    var headDim: Int
+    var numLocalExperts: Int
+    var numExpertsPerToken: Int
+    var interleaveMoeLayerStep: Int
+    var attentionChunkSize: Int
+    var rmsNormEps: Float
+    var ropeTheta: Float
+    var maxPositionEmbeddings: Int
+    var vocabularySize: Int
+    var useQKNorm: Bool
+    var attentionBias: Bool
+    var attnTemperatureTuning: Int
+    var floorScale: Int
+    var attnScale: Float
+    var ropeScaling: [String: StringOrNumber]?
+
+    enum CodingKeys: String, CodingKey {
+        case modelType = "model_type"
+        case hiddenSize = "hidden_size"
+        case hiddenLayers = "num_hidden_layers"
+        case intermediateSize = "intermediate_size"
+        case intermediateSizeMLP = "intermediate_size_mlp"
+        case attentionHeads = "num_attention_heads"
+        case kvHeads = "num_key_value_heads"
+        case headDim = "head_dim"
+        case numLocalExperts = "num_local_experts"
+        case numExpertsPerToken = "num_experts_per_tok"
+        case interleaveMoeLayerStep = "interleave_moe_layer_step"
+        case attentionChunkSize = "attention_chunk_size"
+        case rmsNormEps = "rms_norm_eps"
+        case ropeTheta = "rope_theta"
+        case maxPositionEmbeddings = "max_position_embeddings"
+        case vocabularySize = "vocab_size"
+        case useQKNorm = "use_qk_norm"
+        case attentionBias = "attention_bias"
+        case attnTemperatureTuning = "attn_temperature_tuning"
+        case floorScale = "floor_scale"
+        case attnScale = "attn_scale"
+        case ropeScaling = "rope_scaling"
+    }
+
+    public init(from decoder: Decoder) throws {
+        let c = try decoder.container(keyedBy: CodingKeys.self)
+        self.modelType = try c.decodeIfPresent(String.self, forKey: .modelType) ?? "llama4_text"
+        self.hiddenSize = try c.decode(Int.self, forKey: .hiddenSize)
+        self.hiddenLayers = try c.decode(Int.self, forKey: .hiddenLayers)
+        self.intermediateSize = try c.decode(Int.self, forKey: .intermediateSize)
+        self.intermediateSizeMLP = try c.decode(Int.self, forKey: .intermediateSizeMLP)
+        self.attentionHeads = try c.decode(Int.self, forKey: .attentionHeads)
+        self.kvHeads = try c.decode(Int.self, forKey: .kvHeads)
+        // head_dim may be absent → fall back to hidden_size / heads.
+        if let hd = try c.decodeIfPresent(Int.self, forKey: .headDim) {
+            self.headDim = hd
+        } else {
+            self.headDim = self.hiddenSize / self.attentionHeads
+        }
+        self.numLocalExperts = try c.decode(Int.self, forKey: .numLocalExperts)
+        self.numExpertsPerToken = try c.decode(Int.self, forKey: .numExpertsPerToken)
+        self.interleaveMoeLayerStep =
+            try c.decodeIfPresent(Int.self, forKey: .interleaveMoeLayerStep) ?? 1
+        self.attentionChunkSize =
+            try c.decodeIfPresent(Int.self, forKey: .attentionChunkSize) ?? 8192
+        self.rmsNormEps = try c.decodeIfPresent(Float.self, forKey: .rmsNormEps) ?? 1e-5
+        self.ropeTheta = try c.decodeIfPresent(Float.self, forKey: .ropeTheta) ?? 500000
+        self.maxPositionEmbeddings =
+            try c.decodeIfPresent(Int.self, forKey: .maxPositionEmbeddings) ?? 10485760
+        self.vocabularySize = try c.decode(Int.self, forKey: .vocabularySize)
+        self.useQKNorm = try c.decodeIfPresent(Bool.self, forKey: .useQKNorm) ?? true
+        self.attentionBias = try c.decodeIfPresent(Bool.self, forKey: .attentionBias) ?? false
+        self.attnTemperatureTuning =
+            try c.decodeIfPresent(Int.self, forKey: .attnTemperatureTuning) ?? 4
+        self.floorScale = try c.decodeIfPresent(Int.self, forKey: .floorScale) ?? 8192
+        self.attnScale = try c.decodeIfPresent(Float.self, forKey: .attnScale) ?? 0.1
+        self.ropeScaling = try c.decodeIfPresent(
+            [String: StringOrNumber].self, forKey: .ropeScaling)
+    }
+}
+
+/// Full `llama4` config — wraps the nested `text_config` (mirrors Python `ModelArgs`).
+public struct Llama4Configuration: Codable, Sendable {
+    var modelType: String = "llama4"
+    var textConfig: Llama4TextConfiguration
+
+    enum CodingKeys: String, CodingKey {
+        case modelType = "model_type"
+        case textConfig = "text_config"
+    }
+
+    public init(from decoder: Decoder) throws {
+        let c = try decoder.container(keyedBy: CodingKeys.self)
+        self.modelType = try c.decodeIfPresent(String.self, forKey: .modelType) ?? "llama4"
+        self.textConfig = try c.decode(Llama4TextConfiguration.self, forKey: .textConfig)
+    }
+
+    /// Wrap a bare `llama4_text` config (top-level text-only checkpoint, no
+    /// `text_config` nesting) so `Llama4Model` has a single init path.
+    public init(textConfig: Llama4TextConfiguration) {
+        self.modelType = "llama4"
+        self.textConfig = textConfig
+    }
+}
