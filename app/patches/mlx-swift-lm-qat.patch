+    /// Subclass entry point (used by ``QuantizedScaledLinear``) to supply the
+    /// weight matrix directly.
+    fileprivate init(weight: MLXArray, scalar: Float) {
+        self.weight = weight
+        self.scalar = scalar
+        super.init()
+    }
+
     func callAsFunction(_ x: MLXArray) -> MLXArray {
